# Optional API key auth
API_KEY=

# Requests per minute per client identity
RATE_LIMIT_PER_MINUTE=120

# memory | redis
RATE_LIMIT_BACKEND=memory

# Needed when RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

# Cache backend for expensive HTML pages: memory | redis
CACHE_BACKEND=memory

# Default HTML cache TTL in seconds
CACHE_TTL_SECONDS=300

# Per-domain throttles (seconds between requests)
THROTTLE_COMPANY_INTERVAL_SECONDS=0.2
THROTTLE_SECTOR_INTERVAL_SECONDS=0.2
THROTTLE_SCREENS_INTERVAL_SECONDS=0.2

# Upstream retry behavior for transient failures
UPSTREAM_MAX_RETRIES=2
UPSTREAM_RETRY_BACKOFF_SECONDS=0.5
